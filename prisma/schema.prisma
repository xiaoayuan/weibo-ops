// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum AccountStatus {
  ACTIVE
  DISABLED
  RISKY
  EXPIRED
}

enum AccountLoginStatus {
  UNKNOWN
  ONLINE
  EXPIRED
  FAILED
}

enum TaskStatus {
  PENDING
  READY
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum PlanType {
  CHECK_IN
  FIRST_COMMENT
  POST
  LIKE
  COMMENT
}

enum ActionJobType {
  COMMENT_LIKE_BATCH
  REPOST_ROTATION
}

enum ActionJobStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL_FAILED
  FAILED
  CANCELLED
}

enum ActionStepType {
  COMMENT_LIKE
  REPOST
}

enum ContentStatus {
  ACTIVE
  DISABLED
}

enum ProxyProtocol {
  HTTP
  HTTPS
  SOCKS5
}

enum ProxyRotationMode {
  STICKY
  M1
  M5
  M10
}

enum ProxyBindingMode {
  AUTO
  MANUAL
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  proxyEnabled Boolean @default(false)
  proxyProtocol ProxyProtocol?
  proxyHost String?
  proxyPort Int?
  proxyUsername String?
  proxyPasswordEncrypted String?
  taskConcurrency Int @default(1)
  autoGenerateEnabled Boolean @default(true)
  autoGenerateTime String @default("00:10")
  autoGenerateWindowStart String @default("01:00")
  autoGenerateWindowEnd String @default("22:00")
  autoExecuteEnabled Boolean @default(true)
  autoExecuteStartTime String @default("09:00")
  autoExecuteEndTime String @default("18:00")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  logs         ExecutionLog[]
  actionJobs   ActionJob[]
  ownedAccounts WeiboAccount[] @relation("AccountOwner")
  proxyNodes   ProxyNode[]
}

model ProxyNode {
  id                String        @id @default(cuid())
  ownerUserId       String
  name              String
  protocol          ProxyProtocol @default(HTTP)
  rotationMode      ProxyRotationMode @default(M5)
  countryCode       String?
  host              String
  port              Int
  username          String?
  passwordEncrypted String?
  enabled           Boolean       @default(true)
  maxAccounts       Int           @default(100)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  owner             User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  accounts          WeiboAccount[]

  @@index([ownerUserId, enabled])
  @@unique([ownerUserId, host, port])
}

model InviteCode {
  id          String   @id @default(cuid())
  code        String   @unique
  role        UserRole @default(VIEWER)
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  disabled    Boolean  @default(false)
  createdById String?
  lastUsedBy  String?
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([disabled, expiresAt])
}

model WeiboAccount {
  id                  String             @id @default(cuid())
  ownerUserId         String?
  proxyNodeId         String?
  backupProxyNodeId   String?
  fallbackProxyNodeId String?
  proxyBindingMode    ProxyBindingMode   @default(AUTO)
  proxyBindingLocked  Boolean            @default(false)
  allowHostFallback   Boolean            @default(true)
  nickname            String
  remark              String?
  groupName           String?
  status              AccountStatus      @default(ACTIVE)
  riskLevel           Int                @default(0)
  uid                 String?
  username            String?
  cookieEncrypted     String?
  loginStatus         AccountLoginStatus @default(UNKNOWN)
  cookieUpdatedAt     DateTime?
  lastCheckAt         DateTime?
  loginErrorMessage   String?
  consecutiveFailures Int                @default(0)
  lastActiveAt        DateTime?
  scheduleWindowEnabled Boolean          @default(false)
  executionWindowStart String?
  executionWindowEnd   String?
  baseJitterSec        Int               @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  topicTasks       AccountTopicTask[]
  interactionTasks InteractionTask[]
  plans            DailyPlan[]
  logs             ExecutionLog[]
  actionJobRuns    ActionJobAccountRun[]
  actionJobSteps   ActionJobStep[]
  owner            User?              @relation("AccountOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  proxyNode        ProxyNode?         @relation(fields: [proxyNodeId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([proxyNodeId])
}

model SuperTopic {
  id         String             @id @default(cuid())
  name       String
  boardName  String?
  topicUrl   String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  topicTasks AccountTopicTask[]
  firstCommentLocks FirstCommentPostLock[]
}

model CopywritingTemplate {
  id        String         @id @default(cuid())
  title     String
  content   String
  tags      String[]
  status    ContentStatus  @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  plans     DailyPlan[]
  interactionTasks InteractionTask[]
}

model AccountTopicTask {
  id             String       @id @default(cuid())
  accountId      String
  superTopicId   String
  signEnabled    Boolean      @default(false)
  firstCommentEnabled Boolean  @default(false)
  firstCommentPerDay  Int      @default(4)
  firstCommentIntervalSec Int   @default(1800)
  likePerDay      Int          @default(0)
  likeIntervalSec Int          @default(1200)
  repostPerDay    Int          @default(0)
  repostIntervalSec Int        @default(1800)
  commentPerDay   Int          @default(0)
  commentIntervalSec Int       @default(1800)
  firstCommentTemplates String[]
  postEnabled    Boolean      @default(false)
  minPostsPerDay Int          @default(0)
  maxPostsPerDay Int          @default(0)
  startTime      String?
  endTime        String?
  status         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  account        WeiboAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  superTopic     SuperTopic   @relation(fields: [superTopicId], references: [id], onDelete: Cascade)
  plans          DailyPlan[]

  @@index([accountId])
  @@index([superTopicId])
}

model FirstCommentPostLock {
  id          String    @id @default(cuid())
  planDate    DateTime
  superTopicId String
  statusId    String
  accountId   String?
  taskId      String?
  createdAt   DateTime  @default(now())

  superTopic  SuperTopic @relation(fields: [superTopicId], references: [id], onDelete: Cascade)

  @@unique([planDate, superTopicId, statusId])
  @@index([superTopicId, planDate])
}

model DailyPlan {
  id            String               @id @default(cuid())
  taskId        String?
  accountId     String
  contentId     String?
  planDate      DateTime
  planType      PlanType
  scheduledTime DateTime
  status        TaskStatus           @default(PENDING)
  targetUrl     String?
  resultMessage String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  task          AccountTopicTask?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  account       WeiboAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content       CopywritingTemplate? @relation(fields: [contentId], references: [id], onDelete: SetNull)
  logs          ExecutionLog[]

  @@index([accountId, planDate])
  @@index([status, scheduledTime])
}

model InteractionTarget {
  id             String            @id @default(cuid())
  targetUrl      String
  targetType     String?
  parsedTargetId String?
  status         String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tasks          InteractionTask[]
}

model InteractionTask {
  id            String            @id @default(cuid())
  targetId      String
  accountId     String
   contentId     String?
  actionType    PlanType
  scheduledTime DateTime?
  status        TaskStatus        @default(PENDING)
  resultMessage String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  target        InteractionTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  account       WeiboAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content       CopywritingTemplate? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([targetId])
  @@index([accountId])
  @@index([contentId])
}

model ExecutionLog {
  id              String        @id @default(cuid())
  userId          String?
  accountId       String?
  planId          String?
  actionType      String
  requestPayload  Json?
  responsePayload Json?
  success         Boolean       @default(false)
  errorMessage    String?
  executedAt      DateTime      @default(now())

  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  account         WeiboAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  plan            DailyPlan?    @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([accountId, executedAt])
  @@index([planId])
}

model CommentLinkPoolItem {
  id                String   @id @default(cuid())
  sourceUrl         String
  commentId         String?
  note              String?
  tags              String[]
  isForcedDuplicate Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([commentId])
  @@index([createdAt])
}

model ActionJob {
  id          String          @id @default(cuid())
  jobType     ActionJobType
  status      ActionJobStatus @default(PENDING)
  config      Json
  summary     Json?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  creator     User?               @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  accountRuns ActionJobAccountRun[]
  steps       ActionJobStep[]

  @@index([jobType, createdAt])
  @@index([status, createdAt])
}

model ActionJobAccountRun {
  id           String          @id @default(cuid())
  jobId         String
  accountId     String
  status        ActionJobStatus @default(PENDING)
  currentStep   Int             @default(0)
  totalSteps    Int
  errorMessage  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  job           ActionJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  account       WeiboAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([accountId, createdAt])
}

model ActionJobStep {
  id            String          @id @default(cuid())
  jobId          String
  accountId      String
  stepType       ActionStepType
  targetUrl      String
  payload        Json?
  sequenceNo     Int
  status         ActionJobStatus @default(PENDING)
  resultPayload  Json?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  job            ActionJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  account        WeiboAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([jobId, sequenceNo])
  @@index([accountId, status])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
